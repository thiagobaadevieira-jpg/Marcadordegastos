rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Category Validation ---
    function isValidCategory(data) {
      return data.userId is string 
        && data.userId == request.auth.uid
        && data.name is string 
        && data.name.size() >= 1 
        && data.name.size() <= 64;
    }

    match /categories/{categoryId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(categoryId)
        && isValidCategory(request.resource.data)
        && request.resource.data.keys().hasAll(['userId', 'name'])
        && request.resource.data.keys().size() == 2;
        
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && isValidCategory(request.resource.data)
        && request.resource.data.userId == resource.data.userId
        && request.resource.data.keys().hasAll(['userId', 'name'])
        && request.resource.data.keys().size() == 2;
        
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // --- Transaction Validation ---
    function isValidTransaction(data) {
      return data.userId is string 
        && data.userId == request.auth.uid
        && data.description is string 
        && data.description.size() <= 128
        && data.amount is number
        && data.date is string
        && data.category is string
        && data.type in ['expense', 'income']
        && (data.createdAt == request.time || data.createdAt == null);
    }

    match /transactions/{transactionId} {
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() 
        && isValidId(transactionId)
        && isValidTransaction(request.resource.data)
        && request.resource.data.keys().hasAll(['userId', 'description', 'amount', 'date', 'category', 'type', 'createdAt'])
        && request.resource.data.keys().size() == 7;
        
      allow update: if isSignedIn()
        && resource.data.userId == request.auth.uid
        && isValidTransaction(request.resource.data)
        && request.resource.data.userId == resource.data.userId
        && (
          // Action: Edit fields
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['description', 'amount', 'date', 'category', 'type', 'updatedAt'])
        );
        
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }
  }
}
